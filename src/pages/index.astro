---
import Base from "../layouts/Base.astro";
import RubberBandDecoration from "../components/RubberBandDecoration.astro";
---

<Base>
	<section class="hero" role="region" aria-label="ヒーロー">
		<div class="hero-content">
			<RubberBandDecoration class="hero-decoration animate-scale-in" />
			<div class="hero-text animate-fade-up stagger-2">
				<p class="tagline">輪ゴムっていきなり切れるとびっくりするよね</p>
			</div>
		</div>
	</section>

	<section
		class="section-profile animate-fade-up stagger-3"
		role="region"
		aria-label="プロフィール"
	>
		<h2>輪ごむ について</h2>
		<p>妻と子供の3人で暮しているITエンジニアです</p>
		<p>絵をたまに描きます</p>
	</section>

	<section class="section-likes animate-fade-up stagger-4" role="region" aria-label="好きなもの">
		<h2>好きなもの</h2>

		<div class="likes-grid">
			<div class="likes-item animate-slide-left stagger-5">
				<h3>ツール</h3>
				<ul>
					<li>Vim/Neovim</li>
					<li>Obsidian</li>
				</ul>
			</div>

			<div class="likes-item animate-slide-left stagger-6">
				<h3>言語・フレームワーク</h3>
				<ul>
					<li>Astro</li>
					<li>C#</li>
					<li>CSS</li>
					<li>SQL</li>
					<li>TypeScript</li>
				</ul>
			</div>
		</div>
	</section>
</Base>

<style>
	/* ========== Hero Section - Bold Spacing ========== */
	.hero {
		padding: var(--space-16) 0 var(--space-20);
		margin-bottom: var(--space-8);
		min-height: 50vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.hero-content {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--space-10);
	}

	.hero-decoration {
		flex-shrink: 0;
	}

	.hero-text {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.tagline {
		font-family: var(--font-display);
		font-size: var(--font-size-l);
		color: var(--gray-text);
		font-weight: 400;
		margin: 0;
		line-height: var(--line-height-relaxed);
		max-width: 24ch;
	}

	@media (max-width: 480px) {
		.hero {
			padding: var(--space-10) 0 var(--space-12);
			min-height: auto;
		}

		.hero-content {
			flex-direction: column;
			text-align: center;
			gap: var(--space-6);
		}

		.tagline {
			font-size: var(--font-size-m);
			max-width: none;
		}
	}

	/* ========== Profile Section - Bold Spacing ========== */
	.section-profile {
		padding: var(--space-12) 0;
		margin-bottom: var(--space-8);
	}

	.section-profile h2 {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: var(--font-size-2xl);
		color: var(--accent1);
		margin-top: 0;
		margin-bottom: var(--space-8);
		padding-bottom: var(--space-3);
		border-bottom: 3px solid var(--accent2);
	}

	.section-profile p {
		font-size: var(--font-size-m);
		line-height: var(--line-height-relaxed);
		margin: var(--space-4) 0;
	}

	/* ========== Likes Section - Bold Spacing ========== */
	.section-likes {
		padding: var(--space-12) 0 var(--space-16);
	}

	.section-likes h2 {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: var(--font-size-2xl);
		color: var(--accent1);
		margin-top: 0;
		margin-bottom: var(--space-10);
		padding-bottom: var(--space-3);
		border-bottom: 3px solid var(--accent2);
	}

	.likes-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: var(--space-10);
	}

	.likes-item h3 {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: var(--font-size-l);
		color: var(--accent2);
		margin-top: 0;
		margin-bottom: var(--space-4);
		padding-bottom: var(--space-2);
		border-bottom: 2px solid var(--accent3);
	}

	.likes-item ul {
		padding-left: var(--space-5);
		margin: 0;
	}

	.likes-item li {
		margin: var(--space-2) 0;
		line-height: var(--line-height-normal);
		font-size: var(--font-size-m);
	}

	.likes-item li::marker {
		color: var(--accent3);
	}

	@media (max-width: 480px) {
		.section-profile,
		.section-likes {
			padding: var(--space-8) 0;
		}

		.section-profile h2,
		.section-likes h2 {
			font-size: var(--font-size-xl);
			margin-bottom: var(--space-6);
		}

		.likes-grid {
			gap: var(--space-6);
		}
	}
</style>

<script is:inline>
	/* global toggleTheme */
	(function () {
		var nav = document.querySelector("nav");
		var main = document.querySelector("main");
		var footer = document.querySelector("footer");
		if (!nav || !main || !footer) return;

		// initTheme()がアタッチしたオリジナルのテーマ切替ボタンを保持
		var originalThemeToggle = document.getElementById("theme-toggle");

		// オリジナルfooterのmargin-top: autoを固定値にロック
		var computedMargin = getComputedStyle(footer).marginTop;
		footer.style.marginTop = computedMargin;

		// アニメーションクラスを除去して最終表示状態にする
		function removeAnimations(el) {
			[el].concat(Array.from(el.querySelectorAll("*"))).forEach(function (node) {
				var toRemove = [];
				node.classList.forEach(function (cls) {
					if (cls.startsWith("animate-") || cls.startsWith("stagger-")) {
						toRemove.push(cls);
					}
				});
				toRemove.forEach(function (cls) {
					node.classList.remove(cls);
				});
			});
		}

		// 1サイクル分のクローンを生成
		function createCycleClone() {
			var n = nav.cloneNode(true);
			var m = main.cloneNode(true);
			var f = footer.cloneNode(true);
			f.style.marginTop = computedMargin;
			removeAnimations(n);
			removeAnimations(m);
			removeAnimations(f);
			return { nav: n, main: m, footer: f };
		}

		var before = createCycleClone();
		var after = createCycleClone();

		// clone-before: オリジナルnavの直前に挿入
		document.body.insertBefore(before.nav, nav);
		document.body.insertBefore(before.main, nav);
		document.body.insertBefore(before.footer, nav);

		// clone-after: bodyの末尾に追加
		document.body.appendChild(after.nav);
		document.body.appendChild(after.main);
		document.body.appendChild(after.footer);

		// 1サイクルの高さ = オリジナルnavのドキュメント先頭からの位置
		var oneLoopHeight = nav.getBoundingClientRect().top + window.scrollY;

		// オリジナル位置にジャンプ（初回描画前に実行されるため視覚的に透過）
		window.scrollTo({ top: oneLoopHeight, behavior: "instant" });

		// リサイズ時に再計算
		window.addEventListener("resize", function () {
			oneLoopHeight = nav.getBoundingClientRect().top + window.scrollY;
		});

		// ユーザーを常にオリジナル領域 [H, 2H) に維持する
		window.addEventListener("scroll", function () {
			if (window.scrollY >= oneLoopHeight * 2) {
				window.scrollTo({ top: window.scrollY - oneLoopHeight, behavior: "instant" });
			} else if (window.scrollY < oneLoopHeight) {
				window.scrollTo({ top: window.scrollY + oneLoopHeight, behavior: "instant" });
			}
		});

		// 全クローンのテーマ切替ボタンをイベント委譲で処理
		document.body.addEventListener("click", function (e) {
			var toggle = e.target.closest('[aria-label="テーマを切り替える"]');
			if (toggle && toggle !== originalThemeToggle) {
				toggleTheme();
			}
		});
	})();
</script>
