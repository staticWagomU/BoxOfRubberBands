# Cloudflare R2 Configuration
# These variables are required for R2 OGP caching functionality

# Your Cloudflare account ID
CLOUDFLARE_ACCOUNT_ID=your-account-id

# R2 API credentials
# Create these in Cloudflare Dashboard > R2 > Manage R2 API Tokens
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key

# Optional: Override bucket name (defaults to wrangler.toml configuration)
# CLOUDFLARE_R2_BUCKET_NAME=custom-bucket-name

# Build Options
# Skip OGP generation entirely
# SKIP_OG=true

# Use R2 cache for OGP images
# USE_R2_CACHE=true

# Environment (affects which bucket is used)
# NODE_ENV=production